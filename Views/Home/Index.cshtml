@{
    ViewData["Title"] = "Главная";
    Layout = "_Layout";
}

<div class="hero">
    <div class="hero-content">
        <h1>Атэна</h1>
        <p>Свежие цветы прямо из теплицы</p>
    </div>
</div>

<section class="section">
    <div class="container">
        <h2 class="animate-on-scroll" style="font-size: 2.5rem; font-weight: 800; background: linear-gradient(135deg, #e91e63, #ffd0e0); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">О производстве</h2>
        <p class="animate-on-scroll" style="font-size: 1.1rem; line-height: 1.8;">
            ООО «Тепличное хозяйство Атэна» — это современное предприятие,
            специализирующееся на выращивании цветочной продукции в тепличных условиях.
            Мы предлагаем широкий ассортимент свежих цветов, выращенных с заботой
            и профессионализмом.
        </p>
    </div>
</section>

<section class="section">
    <div class="container">
        <h2 class="animate-on-scroll" style="font-size: 2.5rem; font-weight: 800; background: linear-gradient(135deg, #e91e63, #ffd0e0); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Связь с нами</h2>
        <div class="info-card animate-on-scroll">
            <div class="row">
                <div class="col-sm-6">
                    <p><strong>Адрес:</strong><br>Посёлок Дедуровка, 2</p>
                    <p>Оренбургский район</p>
                    <p>Оренбургская область</p>
                </div>
                <div class="col-sm-6">
                    <p><strong>Телефон:</strong><br>+7 (3532) 00-00-00</p>
                    <p><strong>Email:</strong><br>info@atena-flowers.ru</p>
                    <p><strong>Режим работы:</strong><br>Ежедневно с 9:00 до 20:00</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="glass p-4 animate-on-scroll">
            <h3 class="text-center mb-4" style="color: #e91e63;">Наши преимущества</h3>
            <div class="advantages">
                <div class="adv-card">
                    <div class="icon">🌸</div>
                    <h4>Свежесть</h4>
                    <p>Цветы срезаются в день заказа</p>
                </div>
                <div class="adv-card">
                    <div class="icon">🌿</div>
                    <h4>Качество</h4>
                    <p>Выращено в собственных теплицах</p>
                </div>
                <div class="adv-card">
                    <div class="icon">💐</div>
                    <h4>Ассортимент</h4>
                    <p>Более 50 видов цветов</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <h2 class="text-center animate-on-scroll" style="font-size: 2.5rem; font-weight: 800; background: linear-gradient(135deg, #e91e63, #ffd0e0); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Где нас найти</h2>
        <div class="map-container animate-on-scroll">
            <iframe src="https://yandex.ru/map-widget/v1/?ll=54.67828%2C51.702399&z=15&pt=54.67828,51.702399,pm2rdl"
                    allowfullscreen>
            </iframe>
        </div>
        <div class="text-center mt-3 animate-on-scroll">
            <p style="color: var(--text-muted);">Посёлок Дедуровка, 2, Оренбургский район, Оренбургская область</p>
        </div>
    </div>
</section>

<section class="section text-center">
    <div class="container">
        <h2 class="mb-4 animate-on-scroll" style="font-size: 2rem; color: white;">Готовы порадовать близких?</h2>
        <a href="/Catalog" class="btn btn-primary btn-lg animate-on-scroll">Перейти в каталог</a>
    </div>
</section>