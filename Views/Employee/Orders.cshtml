@model List<WebAtena.Models.Order>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Управление заказами";
    var culture = new System.Globalization.CultureInfo("ru-RU");
}

<div class="container">
    <h2 class="mb-4">Управление заказами</h2>

    <div class="row mb-3">
        <div class="col-md-6">
            <form method="get" class="d-flex">
                <input type="text" name="search" class="form-control me-2" placeholder="Поиск по номеру заказа или имени" value="@ViewBag.SearchTerm" />
                <button type="submit" class="btn btn-primary">Найти</button>
            </form>
        </div>
        <div class="col-md-6 text-end">
            <a href="/Employee/Dashboard" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Назад в панель
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Заказов не найдено.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Номер заказа</th>
                        <th>Имя клиента</th>
                        <th>Телефон</th>
                        <th>Email</th>
                        <th>Статус</th>
                        <th>Дата</th>
                        <th>Сумма</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        var total = order.Items?.Sum(i => i.Price * i.Quantity) ?? 0;
                        <tr>
                            <td><strong>@order.OrderNumber</strong></td>
                            <td>@order.CustomerName</td>
                            <td>@order.Phone</td>
                            <td>@order.Email</td>
                            <td>
                                <span class="badge @(order.Status == "Новый" ? "bg-warning" : order.Status == "В обработке" ? "bg-info" : order.Status == "Выполнен" ? "bg-success" : "bg-danger")">
                                    @order.Status
                                </span>
                            </td>
                            <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@total.ToString("C", culture)</td>
                            <td>
                                <a href="/Employee/OrderDetails/@order.Id" class="btn btn-primary btn-sm">
                                    <i class="bi bi-eye"></i> Детали
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>