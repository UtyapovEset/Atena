@model WebAtena.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = "_Layout";
    ViewData["Title"] = "Добавление товара";
}

<div class="container pt-4">
    <h2 class="mb-4" style="color: white;">Добавление нового товара</h2>

    <form method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Название *</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ShortDescription" class="form-label">Краткое описание</label>
                    <textarea asp-for="ShortDescription" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Полное описание</label>
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label">Цена *</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" required />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Stock" class="form-label">Количество на складе *</label>
                    <input asp-for="Stock" class="form-control" type="number" min="0" value="0" required />
                    <small class="text-muted">Если 0 - товар будет отображаться как "Нет в наличии"</small>
                    <span asp-validation-for="Stock" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label">Категория *</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                        <option value="">-- Выберите категорию --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Изображение</label>
                    <input type="file" name="image" class="form-control" accept="image/*" />
                    <small class="text-muted">Поддерживаются форматы: JPG, PNG, GIF</small>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Добавить товар</button>
                    <a href="/Employee/Products" class="btn btn-outline-primary ms-2">Отмена</a>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card" style="background: #41414f; border: 1px solid #334155;">
                    <div class="card-header" style="background: rgba(76, 175, 80, 0.2); border-bottom: 2px solid #4caf50;">
                        <h5 class="mb-0" style="color: white !important;"><i class="bi bi-info-circle"></i> Подсказка</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-2" style="color: #ffffff !important;"><strong>Как заполнять поля:</strong></p>
                        <ul class="small" style="color: #ffffff;">
                            <li><strong>Название</strong> - основное наименование товара</li>
                            <li><strong>Краткое описание</strong> - отображается в карточке товара</li>
                            <li><strong>Полное описание</strong> - подробная информация на странице товара</li>
                            <li><strong>Цена</strong> - стоимость в рублях</li>
                            <li><strong>Количество на складе</strong> - остаток товара</li>
                            <li><strong>Категория</strong> - раздел каталога</li>
                            <li><strong>Изображение</strong> - фото товара (рекомендуемый размер 500x500)</li>
                        </ul>
                        <hr style="border-color: rgba(255,255,255,0.3);">
                        <p class="small mb-0" style="color: #ffffff;">
                            <i class="bi bi-cart-check"></i> При оформлении заказа количество товара уменьшится автоматически.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}