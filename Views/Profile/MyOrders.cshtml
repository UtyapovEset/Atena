@model List<WebAtena.Models.Order>
@{
    ViewData["Title"] = "Мои заказы";
    Layout = "_Layout";
    var culture = new System.Globalization.CultureInfo("ru-RU");
}

<div class="container py-5">
    <h2 class="mb-4">Мои заказы</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="bi bi-cart-x display-1" style="color: rgba(255,255,255,0.3);"></i>
            <h4 class="mt-3">У вас пока нет заказов</h4>
            <a href="/Catalog" class="btn btn-primary mt-3">Перейти в каталог</a>
        </div>
    }
    else
    {
        <div class="card glass">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Номер заказа</th>
                                <th>Дата</th>
                                <th>Статус</th>
                                <th class="text-end">Сумма</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                var total = order.Items?.Sum(i => i.Price * i.Quantity) ?? 0;
                                <tr>
                                    <td><strong>@order.OrderNumber</strong></td>
                                    <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge @(order.Status == "Новый" ? "bg-warning" :
                                                             order.Status == "В обработке" ? "bg-info" :
                                                             order.Status == "Выполнен" ? "bg-success" : "bg-danger")">
                                    @order.Status
                                </span>
                            </td>
                            <td class="text-end fw-bold">@total.ToString("C", culture)</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a href="/Order/Success/@order.Id" class="btn btn-sm btn-primary">
                                        <i class="bi bi-eye"></i> Подробнее
                                    </a>
                                    @if (order.Status == "Новый")
                                            {
                                                <form method="post" asp-action="CancelOrder" onsubmit="return confirm('Отменить заказ @order.OrderNumber?');">
                                                    <input type="hidden" name="orderId" value="@order.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                        <i class="bi bi-x-circle"></i> Отменить
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>