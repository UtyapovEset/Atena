@model IEnumerable<WebAtena.Models.Product>
@{
    ViewData["Title"] = "Каталог цветов";
    var culture = new System.Globalization.CultureInfo("ru-RU");
}

<div class="container pt-4">
    <h2 class="text-center mb-5 animate-on-scroll">Каталог цветов</h2>

    <div class="glass p-4 mb-5">
        <form method="get">
            <div class="search-filter-row">
                <select name="categoryId" class="form-select">
                    <option value="">Все категории</option>
                    @foreach (var cat in ViewBag.Categories)
                    {
                        <option value="@cat.Id" selected="@(ViewBag.CurrentCategory == cat.Id)">@cat.Name</option>
                    }
                </select>
                <input type="text" name="search" class="form-control" placeholder="Поиск по названию..." value="@ViewBag.SearchTerm" />
                <button type="submit" class="btn btn-primary">Найти</button>
            </div>
        </form>
    </div>

    <div class="row">
        @if (Model.Any())
        {
            @foreach (var product in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 position-relative">
                        @if (product.Stock > 10)
                        {
                            <span class="product-badge">Хит</span>
                        }
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name">
                        }
                        else
                        {
                            <div class="card-img-top d-flex align-items-center justify-content-center" style="background: rgba(255,255,255,0.05);">
                                <i class="bi bi-image" style="font-size: 3rem; color: rgba(255,255,255,0.3);"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@product.Name</h5>
                            <p style="color: var(--text-muted);">@product.ShortDescription</p>
                            <div class="mb-3">
                                @if (product.Stock > 0)
                                {
                                    <span class="badge badge-success">В наличии (@product.Stock шт.)</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">Нет в наличии</span>
                                }
                            </div>
                            <div class="mt-auto">
                                <div class="price">@product.Price.ToString("C", culture)</div>
                                <div class="d-flex gap-2">
                                    <a href="/Catalog/Details/@product.Id" class="btn btn-outline-primary flex-grow-1 btn-sm">Подробнее</a>
                                    @if (product.Stock > 0)
                                    {
                                        <button onclick="showAddToCartModal(@product.Id, '@product.Name.Replace("'", "\\'")')" class="btn btn-primary flex-grow-1 btn-sm">
                                            В корзину
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="glass p-5">
                    <i class="bi bi-emoji-frown" style="font-size: 4rem; color: rgba(255,255,255,0.3);"></i>
                    <h3 class="mt-4">Товары не найдены</h3>
                    <p style="color: var(--text-muted);">Попробуйте изменить параметры поиска</p>
                    <a href="/Catalog" class="btn btn-primary">Сбросить фильтры</a>
                </div>
            </div>
        }
    </div>
</div>