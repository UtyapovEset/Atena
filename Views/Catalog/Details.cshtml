@model WebAtena.Models.Product
@{
    ViewData["Title"] = Model.Name;
    var culture = new System.Globalization.CultureInfo("ru-RU");
}

<div class="container pt-4">
    <div class="row g-5">
        <div class="col-lg-6">
            <div class="glass p-3">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="img-fluid rounded-3" alt="@Model.Name" style="width: 100%; max-height: 500px; object-fit: cover;">
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center rounded-3" style="height: 500px; background: rgba(255,255,255,0.05);">
                        <i class="bi bi-image" style="font-size: 5rem; color: rgba(255,255,255,0.3);"></i>
                    </div>
                }
            </div>
        </div>
        <div class="col-lg-6">
            <h2 style="font-size: 2.5rem; font-weight: 700; color: white;">@Model.Name</h2>
            <p style="color: var(--text-muted); font-size: 1.1rem;">@Model.ShortDescription</p>
            <hr style="border-color: rgba(255,255,255,0.1);">

            <div class="mb-4">
                @if (Model.Stock > 0)
                {
                    <span class="badge badge-success" style="font-size: 1rem;">В наличии (@Model.Stock шт.)</span>
                }
                else
                {
                    <span class="badge badge-danger" style="font-size: 1rem;">Нет в наличии</span>
                }
            </div>

            <p style="font-size: 1.1rem; line-height: 1.8; color: var(--text-muted);">@Model.Description</p>

            <div class="info-card mb-4">
                <p><strong>Категория:</strong> @Model.Category?.Name</p>
                <p><strong>Цена:</strong> <span class="price" style="font-size: 2rem;">@Model.Price.ToString("C", culture)</span></p>
            </div>

            <div class="d-flex gap-3">
                @if (Model.Stock > 0)
                {
                    <button onclick="showAddToCartModal(@Model.Id, '@Model.Name.Replace("'", "\\'")')" class="btn btn-primary btn-lg flex-grow-1">
                        <i class="bi bi-cart-check"></i> В корзину
                    </button>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg flex-grow-1" disabled>
                        <i class="bi bi-cart-x"></i> Нет в наличии
                    </button>
                }
                <a href="/Catalog" class="btn btn-outline-primary btn-lg">
                    <i class="bi bi-arrow-left"></i> Назад
                </a>
            </div>
        </div>
    </div>
</div>