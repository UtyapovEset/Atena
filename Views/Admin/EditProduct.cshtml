@model WebAtena.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = "_Layout";
    ViewData["Title"] = "пЕДЮЙРХПНБЮМХЕ РНБЮПЮ";
}

<div class="container pt-4">
    <h2 class="mb-4" style="color: white;">пЕДЮЙРХПНБЮМХЕ РНБЮПЮ</h2>

    <form method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">мЮГБЮМХЕ *</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ShortDescription" class="form-label">йПЮРЙНЕ НОХЯЮМХЕ</label>
                    <textarea asp-for="ShortDescription" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">оНКМНЕ НОХЯЮМХЕ</label>
                    <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                </div>

                <div class="mb-3">
                    <label asp-for="Price" class="form-label">жЕМЮ *</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" required />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Stock" class="form-label">йНКХВЕЯРБН МЮ ЯЙКЮДЕ *</label>
                    <input asp-for="Stock" class="form-control" type="number" min="0" required />
                    <small class="text-muted">еЯКХ 0 - РНБЮП АСДЕР НРНАПЮФЮРЭЯЪ ЙЮЙ "мЕР Б МЮКХВХХ"</small>
                    <span asp-validation-for="Stock" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoryId" class="form-label">йЮРЕЦНПХЪ *</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                        <option value="">-- бШАЕПХРЕ ЙЮРЕЦНПХЧ --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">рЕЙСЫЕЕ ХГНАПЮФЕМХЕ</label>
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <div>
                            <img src="@Model.ImageUrl" style="max-width: 200px;" class="img-thumbnail" />
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">мЕР ХГНАПЮФЕМХЪ</p>
                    }
                </div>

                <div class="mb-3">
                    <label class="form-label">мНБНЕ ХГНАПЮФЕМХЕ</label>
                    <input type="file" name="image" class="form-control" accept="image/*" />
                    <small class="text-muted">нЯРЮБЭРЕ ОСЯРШЛ, ВРНАШ ЯНУПЮМХРЭ РЕЙСЫЕЕ ХГНАПЮФЕМХЕ</small>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">яНУПЮМХРЭ</button>
                    <a href="/Admin/Products" class="btn btn-outline-primary ms-2">нРЛЕМЮ</a>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card" style="background: #41414f; border: 1px solid #334155;">
                    <div class="card-header" style="background: rgba(33, 150, 243, 0.2); border-bottom: 2px solid #2196f3;">
                        <h5 class="mb-0" style="color: white !important;"><i class="bi bi-box-seam"></i> хМТНПЛЮЖХЪ Н ЙНКХВЕЯРБЕ</h5>
                    </div>
                    <div class="card-body">
                        <p style="color: #ffffff !important;">рЕЙСЫЕЕ ЙНКХВЕЯРБН МЮ ЯЙКЮДЕ: <strong class="fs-4" style="color: #ffffff !important;">@Model.Stock ЬР.</strong></p>
                        <p style="color: #ffffff !important;">
                            яРЮРСЯ:
                            @if (Model.Stock > 0)
                            {
                                <span class="badge badge-success">б МЮКХВХХ (@Model.Stock ЬР.)</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">мЕР Б МЮКХВХХ</span>
                            }
                        </p>
                        <hr style="border-color: rgba(255,255,255,0.3);">
                        <p class="small" style="color: #ffffff;">
                            <i class="bi bi-info-circle"></i> оПХ НТНПЛКЕМХХ ГЮЙЮГЮ ЙНКХВЕЯРБН ЮБРНЛЮРХВЕЯЙХ СЛЕМЭЬЮЕРЯЪ МЮ 1 ГЮ ЙЮФДШИ РНБЮП.
                        </p>
                        <div class="alert alert-warning small" style="color: #ffa726 !important; background: rgba(255, 167, 38, 0.1); border-color: rgba(255, 167, 38, 0.3);">
                            <i class="bi bi-exclamation-triangle"></i> бМХЛЮМХЕ: ЕЯКХ ЙНКХВЕЯРБН ЯРЮМЕР 0, РНБЮП ОЕПЕЯРЮМЕР НРНАПЮФЮРЭЯЪ ЙЮЙ ДНЯРСОМШИ ДКЪ ГЮЙЮГЮ.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}