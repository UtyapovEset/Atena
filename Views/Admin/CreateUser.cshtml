@model WebAtena.Models.UserViewModel
@{
    ViewData["Title"] = "Создание пользователя";
    Layout = "_Layout";
}

<div class="container pt-4">
    <h2 class="mb-4" style="color: white;">Создание нового пользователя</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card glass">
                <div class="card-body">
                    <form method="post" action="/Admin/CreateUser">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label">ФИО</label>
                            <input type="text" name="fullName" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Логин</label>
                            <input type="text" name="login" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Телефон</label>
                            <input type="text" name="phone" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Пароль</label>
                            <input type="password" name="password" class="form-control" required />
                            <small class="text-muted">Минимум 6 символов</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Роль</label>
                            <select name="role" class="form-select">
                                <option value="Customer">Покупатель</option>
                                <option value="Employee">Сотрудник</option>
                                <option value="Admin">Администратор</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary">Создать</button>
                        <a href="/Admin/Users" class="btn btn-outline-primary ms-2">Отмена</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>