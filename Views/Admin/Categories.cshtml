@model IEnumerable<WebAtena.Models.Category>
@{
    ViewData["Title"] = "Управление категориями";
    Layout = "_Layout";
}

<div class="container pt-4">
    <h2 class="mb-4" style="color: white;">Управление категориями</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0 text-white">Добавить категорию</h5>
                </div>
                <div class="card-body text-light">
                    <form method="post" action="/Admin/CreateCategory">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label text-white">Название</label>
                            <input type="text" name="Name" class="form-control text-light" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-white">Описание</label>
                            <textarea name="Description" class="form-control text-light" rows="4"></textarea>
                        </div>
                        <button type="submit" class="btn btn-success">Добавить</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Список категорий</h5>
                </div>
                <div class="card-body">
                    @if (!Model.Any())
                    {
                        <p class="text-muted">Категорий пока нет</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Название</th>
                                        <th>Описание</th>
                                        <th>Товаров</th>
                                        <th>Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cat in Model)
                                    {
                                        <tr>
                                            <td>@cat.Name</td>
                                            <td>@cat.Description</td>
                                            <td>@(cat.Products?.Count ?? 0)</td>
                                            <td>
                                                <form method="post" action="/Admin/DeleteCategory/@cat.Id"
                                                      onsubmit="return confirm('Удалить категорию?');" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a href="/Admin/Dashboard" class="btn btn-secondary">Назад</a>
    </div>
</div>