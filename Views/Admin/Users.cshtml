@model IEnumerable<WebAtena.Models.UserViewModel>
@{
    ViewData["Title"] = "Управление пользователями";
    Layout = "_Layout";
    string currentRole = ViewBag.RoleFilter ?? "All";
    string currentSearch = ViewBag.SearchTerm ?? "";
}

<div class="container pt-4">
    <h2 class="mb-4">Управление пользователями</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="row mb-3">
        <div class="col-md-8">
            <form method="get" class="d-flex gap-2">
                <select name="roleFilter" class="form-select" style="width: 220px;">
                    <option value="All" selected="@(currentRole == "All")">Все роли</option>
                    <option value="Admin" selected="@(currentRole == "Admin")">Администраторы</option>
                    <option value="Employee" selected="@(currentRole == "Employee")">Сотрудники</option>
                    <option value="Customer" selected="@(currentRole == "Customer")">Покупатели</option>
                </select>
                <input type="text" name="search" class="form-control" placeholder="Поиск по логину, ФИО или email" value="@currentSearch" />
                <button type="submit" class="btn btn-primary">Фильтровать</button>
            </form>
        </div>
        <div class="col-md-4 text-end">
            <a href="/Admin/CreateUser" class="btn btn-success">+ Создать пользователя</a>
        </div>
    </div>

    <div class="card glass">
        <div class="card-body">
            <form id="bulkForm" method="post">
                <div class="table-responsive">
                    <table class="table table-hover" id="usersTable">
                        <thead>
                            <tr>
                                <th style="width: 50px;">
                                    <input type="checkbox" id="selectAll">
                                </th>
                                <th>Логин</th>
                                <th>ФИО</th>
                                <th>Email</th>
                                <th>Телефон</th>
                                <th>Роль</th>
                                <th>Дата регистрации</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" name="selectedUsers" value="@user.Id" class="user-checkbox">
                                    </td>
                                    <td>@user.Login</td>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td>@user.Phone</td>
                                    <td>
                                        <span class="badge @(user.Role == "Admin" ? "bg-danger" : user.Role == "Employee" ? "bg-info" : "bg-secondary")">
                                            @user.Role
                                        </span>
                                    </td>
                                    <td>@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3 d-flex gap-3 align-items-center">
                    <select id="bulkRole" name="role" class="form-select" style="width: 200px;">
                        <option value="Customer">Покупатель</option>
                        <option value="Employee">Сотрудник</option>
                        <option value="Admin">Администратор</option>
                    </select>
                    <button type="button" onclick="submitBulkAction('/Admin/BulkUpdateRole')" class="btn btn-warning">Сменить роль у выбранных</button>
                    <button type="button" onclick="submitBulkAction('/Admin/BulkDeleteUsers')" class="btn btn-danger">Удалить выбранных</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('selectAll').addEventListener('change', function () {
            document.querySelectorAll('.user-checkbox').forEach(cb => cb.checked = this.checked);
        });

        function getSelectedIds() {
            return Array.from(document.querySelectorAll('.user-checkbox:checked')).map(cb => cb.value);
        }

        function submitBulkAction(url) {
            const ids = getSelectedIds();
            if (ids.length === 0) {
                alert("Выберите пользователей");
                return;
            }

            if (url.includes('Delete')) {
                if (!confirm(`Удалить ${ids.length} пользователей?`)) return;
            } else {
                const role = document.getElementById('bulkRole').value;
                if (!confirm(`Изменить роль у ${ids.length} пользователей на "${role}"?`)) return;
            }

            const form = document.getElementById('bulkForm');
            form.action = url;
            form.submit();
        }
    </script>
}