@model WebAtena.Models.Order
@{
    ViewData["Title"] = "Заказ оформлен";
    var culture = new System.Globalization.CultureInfo("ru-RU");
}

<div class="container pt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card mt-5 glass">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="bi bi-check-circle-fill" style="font-size: 6rem; color: #4caf50;"></i>
                    </div>

                    <h2 class="mb-3" style="color: #4caf50;">Спасибо за заказ!</h2>

                    @if (Model != null)
                    {
                        <p class="lead fs-4">Номер вашего заказа: <strong class="text-white">@Model.OrderNumber</strong></p>

                        @if (Model.Items != null && Model.Items.Any())
                        {
                            var total = Model.Items.Sum(i => i.Quantity * i.Price);
                            <p class="fs-3 fw-bold" style="color: #e91e63;">
                                Сумма заказа: @total.ToString("C", culture)
                            </p>
                        }
                    }

                    <p class="mb-4" style="color: var(--text-muted); font-size: 1.1rem;">
                        Наш менеджер свяжется с вами в ближайшее время для подтверждения.
                    </p>

                    <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                        <a href="/Catalog" class="btn btn-primary btn-lg px-4">
                            <i class="bi bi-grid-3x3-gap"></i> Продолжить покупки
                        </a>
                        <a href="/" class="btn btn-outline-primary btn-lg px-4">
                            <i class="bi bi-house"></i> На главную
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>